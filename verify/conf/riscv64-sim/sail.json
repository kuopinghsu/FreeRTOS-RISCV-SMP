// sail.json — Sail reference model configuration for riscv64-sim RV64IMAC
// SPDX-License-Identifier: Apache-2.0
//
// This file configures sail_riscv_sim when it generates reference signatures
// for arch-tests against riscv64-sim.  It describes the ISA and memory layout
// that Sail should emulate to produce results comparable with riscv64-sim.
//
// riscv64-sim address map:
//   0x02000000  CLINT  (MSIP, mtimecmp at +0x4000, mtime at +0xBFF8)
//   0x80000000  RAM    128 MB  (code + data + HTIF)
//   0x83FFF000  HTIF   4 KB   (tohost/fromhost — ELF-symbol-resolved, within RAM)
//   Unmapped regions → EXC_LOAD/STORE_ACCESS_FAULT (cause=5/7)
{
  "$schema": "/usr/local/share/sail-riscv/sail_riscv_config_schema.json",
  "base": {
    "xlen": 64,
    "E": false,
    // misa is read-only in the simulator (hardwired to RV64IMAC)
    "writable_misa": false,
    "writable_fiom": false,
    "writable_hpm_counters": {
      "len": 32,
      // Simulator has no HPM counters (only mcycle and minstret, always counting)
      "value": "0x00000000"
    },
    // No S-mode → scounteren bits are read-only zero
    "scounteren_writable_bits": {
      "len": 32,
      "value": "0x00000000"
    },
    "xtval_nonzero": {
      // mtval behaviour for riscv64-sim:
      //   EXC_ILLEGAL_INSTR            → mtval = instruction encoding
      //   EXC_BREAKPOINT               → mtval = 0
      //   EXC_ECALL_MMODE              → mtval = 0
      //   EXC_LOAD/STORE_MISALIGNED    → mtval = fault address
      //   EXC_LOAD/STORE_ACCESS_FAULT  → mtval = fault address
      //   EXC_FETCH_ACCESS_FAULT       → mtval = fetch PC
      //   IRQ                          → mtval = 0
      "illegal_instruction": true,
      "software_breakpoint": false,
      "hardware_breakpoint": false,
      "load_address_misaligned": true,
      "load_access_fault": true,
      "load_page_fault": false,
      "samo_address_misaligned": true,
      "samo_access_fault": true,
      "samo_page_fault": false,
      // C extension (IALIGN=16): hardware aligns branch/jump targets to 2 bytes,
      // so fetch-misaligned exceptions never occur in practice.
      "fetch_address_misaligned": false,
      "fetch_access_fault": true,
      "fetch_page_fault": false,
      "software_check": false,
      "reserved_exceptions": false
    },
    "reserved_behavior": {
      "amocas_odd_register": "AMOCAS_Illegal",
      "fcsr_rm": "Fcsr_RM_Illegal",
      "pmpcfg_write_only": "PMP_ClearPermissions",
      "xenvcfg_cbie": "Xenvcfg_ClearPermissions",
      // mtvec bit[1] is hardwired 0; writes with MODE >= 2 are ignored.
      "xtvec_mode": "Xtvec_Ignore",
      "rv32zdinx_odd_register": "Zdinx_Illegal"
    }
  },
  "memory": {
    "pmp": {
      // riscv64-sim has no PMP
      "grain": 0,
      "count": 0,
      "usable_count": 0,
      "tor_supported": false,
      "na4_supported": false,
      "napot_supported": false
    },
    "misaligned": {
      // Simulator raises EXC_LOAD_ADDR_MISALIGNED (cause=4) or
      // EXC_STORE_ADDR_MISALIGNED (cause=6) for any misaligned load or store.
      // Misaligned AMOs raise EXC_STORE_AMO_ACCESS_FAULT (cause=7).
      "exceptions": {
        "load_store": { "Some": "AlignmentException" },
        "vector": { "None": null },
        "lrsc": "AccessFault",
        "amo": "AccessFault"
      },
      "allowed_within_exp": 0,
      "byte_by_byte": false,
      "order_decreasing": false
    },
    "translation": {
      "dirty_update": false
    },
    "dtb_address": {
      // Device tree blob address — not used by arch-test ELFs; placed safely
      // at 48 MB into RAM, well past any test code or data.
      "len": 64,
      "value": "0x83000000"
    },
    "regions": [
      // CLINT: 0x02000000 — covers MSIP (0x02000000), mtimecmp (0x02004000),
      // and mtime (0x0200BFF8).  Size 0xC0000 = 768 KB covers all three.
      {
        "base": { "len": 64, "value": "0x02000000" },
        "size": { "len": 64, "value": "0xC0000" },
        "attributes": {
          "mem_type": "IOMemory",
          "cacheable": false,
          "coherent": true,
          "executable": false,
          "readable": true,
          "writable": true,
          "read_idempotent": false,
          "write_idempotent": false,
          "misaligned_exceptions": {
            "load_store": { "Some": "AlignmentException" },
            "vector": { "None": null },
            "amo": "AccessFault"
          },
          "atomic_support": "AMONone",
          "reservability": "RsrvNone",
          "supports_cbo_zero": false,
          "supports_pte_read": false,
          "supports_pte_write": false
        },
        "include_in_device_tree": false
      },
      // RAM: 0x80000000  128 MB — code, data, signature, HTIF all live here.
      // arch-test ELFs are loaded at 0x80000000; HTIF is at 0x83FFF000.
      {
        "base": { "len": 64, "value": "0x80000000" },
        "size": { "len": 64, "value": "0x8000000" },
        "attributes": {
          "mem_type": "MainMemory",
          "cacheable": true,
          "coherent": true,
          "executable": true,
          "readable": true,
          "writable": true,
          "read_idempotent": true,
          "write_idempotent": true,
          "misaligned_exceptions": {
            "load_store": { "Some": "AlignmentException" },
            "vector": { "None": null },
            "amo": "AccessFault"
          },
          "atomic_support": "AMOArithmetic",  // Zaamo: all AMOs except AMOCAS
          "reservability": "RsrvEventual",
          "supports_cbo_zero": false,
          "supports_pte_read": false,   // no MMU
          "supports_pte_write": false
        },
        "include_in_device_tree": true
      }
    ]
  },
  "platform": {
    "vendorid": 0,
    "archid": 0,
    "impid": 1,
    "hartid": 0,
    "cache_block_size_exp": 6,
    "reservation": {
      // LR/SC reservation set matches the access size (minimum granule = 8 bytes).
      "reservation_set_size_exp": 3,
      "require_exact_reservation_addr": false
    },
    // CLINT base: 0x02000000; size covers MSIP, mtimecmp (+0x4000), mtime (+0xBFF8)
    "clint": {
      "base": 33554432,   // 0x02000000
      "size": 786432      // 0xC0000 — covers mtime at base+0xBFF8
    },
    // Interrupt generator placed at unused address within the CLINT IO region.
    // Arch tests for I/M/A/C extensions do not use this device; required by schema.
    "simple_interrupt_generator": {
      "base": 35651584    // 0x02200000 (within CLINT IO region)
    },
    "clock_frequency": 50000000,
    "instructions_per_tick": 2,
    "wfi_is_nop": false,
    "max_time_to_wait": 100
  },
  "extensions": {
    "M": { "supported": true },
    "A": { "supported": false },  // Handled as Zaamo + Zalrsc separately
    "F": { "supported": false },
    "D": { "supported": false },
    "V": {
      "support_level": "Disabled",
      "vlen_exp": 7,
      "elen_exp": 6,
      "vl_use_ceil": false
    },
    "B": { "supported": false },
    "S": { "supported": false },
    "U": { "supported": false },
    "Zibi": { "supported": false },
    "Zicbom": { "supported": false },
    "Zicbop": { "supported": false },
    "Zicboz": { "supported": false },
    "Zic64b": { "supported": false },
    "Zicfilp": { "supported": false },
    "Zicond": { "supported": false },
    "Ziccamoa": { "supported": false },
    "Ziccamoc": { "supported": false },
    "Ziccif": { "supported": false },
    "Zicclsm": { "supported": false },
    "Ziccrse": { "supported": false },
    "Zicfiss": { "supported": false },
    "Zicntr": { "supported": true },
    "Zicsr": { "supported": true },
    "Zifencei": { "supported": true },
    "Zihintntl": { "supported": false },
    "Zihintpause": { "supported": false },
    "Zihpm": { "supported": false },
    "Zimop": { "supported": false },
    "Zmmul": { "supported": false },
    "Zaamo": { "supported": true },
    "Zabha": { "supported": false },
    "Zacas": { "supported": false },
    "Zalrsc": { "supported": true },
    "Zawrs": {
      "supported": false,
      "nto": { "is_nop": false },
      "sto": { "is_nop": false }
    },
    "Zfa": { "supported": false },
    "Zfbfmin": { "supported": false },
    "Zfh": { "supported": false },
    "Zfhmin": { "supported": false },
    "Zfinx": { "supported": false },
    "Zdinx": { "supported": false },
    "Zca": { "supported": true },
    "Zcf": { "supported": false },
    "Zcd": { "supported": false },
    "Zcb": { "supported": false },
    "Zcmp": { "supported": false },
    "Zcmop": { "supported": false },
    "Zba": { "supported": false },
    "Zbb": { "supported": false },
    "Zbs": { "supported": false },
    "Zbc": { "supported": false },
    "Zbkb": { "supported": false },
    "Zbkc": { "supported": false },
    "Zbkx": { "supported": false },
    "Zknd": { "supported": false },
    "Zkne": { "supported": false },
    "Zknh": { "supported": false },
    "Zkr": {
      "supported": false,
      "sseed_reset_value": false,
      "useed_reset_value": false,
      "sseed_read_only_zero": false,
      "useed_read_only_zero": false
    },
    "Zksed": { "supported": false },
    "Zksh": { "supported": false },
    "Zkt": { "supported": false },
    "Zhinx": { "supported": false },
    "Zhinxmin": { "supported": false },
    "Sscofpmf": { "supported": false },
    "Ssccptr": { "supported": false },
    "Sscounterenw": { "supported": false },
    "Sstc": { "supported": false },
    "Sstvala": { "supported": false },
    "Svinval": { "supported": false },
    "Svrsw60t59b": { "supported": false },
    "Svade": { "supported": false },
    "Svadu": { "supported": false },
    "Svnapot": { "supported": false },
    "Svpbmt": { "supported": false },
    "Svvptc": { "supported": false },
    "Smcntrpmf": { "supported": false },
    "Svbare": {
      "supported": false,
      "sfence_vma_illegal_if_svbare_only": true
    },
    "Sv32": { "supported": false },
    "Sv39": { "supported": false },
    "Sv48": { "supported": false },
    "Sv57": { "supported": false },
    "Stateen": {
      "Smstateen": { "supported": false },
      "Ssstateen": { "supported": false },
      "C_readonly_zero": true,
      "SE0_readonly_zero": false
    },
    "Ssqosid": {
      "supported": false,
      "rcid_length": 12,
      "mcid_length": 12
    },
    "Zvabd": { "supported": false },
    "Zvbb": { "supported": false },
    "Zvbc": { "supported": false },
    "Zvfbfmin": { "supported": false },
    "Zvfbfwma": { "supported": false },
    "Zvfh": { "supported": false },
    "Zvfhmin": { "supported": false },
    "Zvkb": { "supported": false },
    "Zvkg": { "supported": false },
    "Zvkned": { "supported": false },
    "Zvknha": { "supported": false },
    "Zvknhb": { "supported": false },
    "Zvksed": { "supported": false },
    "Zvksh": { "supported": false },
    "Zvkt": { "supported": false }
  }
}
